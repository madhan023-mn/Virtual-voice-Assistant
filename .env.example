# ──────────────────────────────────────────────────────────────────────────────
# ARIA Virtual Voice Assistant — Environment Variables
# Copy this file to .env and fill in your actual API keys
# NEVER commit your .env file to version control
# ──────────────────────────────────────────────────────────────────────────────

# Flask
SECRET_KEY=my-secret-key-2026
FLASK_ENV=development
DEBUG=True
PORT=5000

# ── AI Backends (use at least ONE) ──────────────────────────────────────────
# Google Gemini API key — get it at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

# OpenAI API key (fallback if Gemini not set) — get at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# ── Weather ──────────────────────────────────────────────────────────────────
# OpenWeatherMap API key — get at https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_key_here
DEFAULT_CITY=New York

# ── News ─────────────────────────────────────────────────────────────────────
# NewsAPI key — get at https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# ── Currency Conversion ───────────────────────────────────────────────────────
# ExchangeRate-API key (optional) — get at https://www.exchangerate-api.com
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key_here

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to specific origins in production, e.g.: https://your-domain.com
CORS_ORIGINS=*

# ── New APIs ─────────────────────────────────────────────────────────────────
# Groq API Key - https://console.groq.com
GROQ_API_KEY=
# OpenRouter API Key - https://openrouter.ai
OPENROUTER_API_KEY=
# HuggingFace API Key - https://huggingface.co
HUGGINGFACE_API_KEY=
# Spotify - https://developer.spotify.com
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# OMDb API - https://www.omdbapi.com
OMDB_API_KEY=
# NASA API - https://api.nasa.gov
NASA_API_KEY=DEMO_KEY
